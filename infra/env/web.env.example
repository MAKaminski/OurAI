# apps/web — copy to apps/web/.env.local and fill in.

# Supabase (public — safe to expose to the browser; constrained by RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostHog analytics (leave blank to disable analytics entirely)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Public site URL (used for canonical URLs, sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://ourai.dev

# Social-proof waitlist counter. Kill switch (on by default) + the minimum
# number of pre-signups before the count is revealed to visitors.
NEXT_PUBLIC_WAITLIST_COUNT_ENABLED=true
NEXT_PUBLIC_WAITLIST_MIN_REVEAL=20

# Server-only. Supabase service role (writes waitlist + reads/writes BYOK settings)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Encrypts sensitive BYOK settings at rest (any strong random string).
# The orchestrator must use the SAME value to decrypt them at runtime.
SETTINGS_ENCRYPTION_KEY=
