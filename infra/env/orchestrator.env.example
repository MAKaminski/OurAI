# apps/orchestrator — copy to apps/orchestrator/.env and fill in.

# --- Model gateway ---
MODEL_PROVIDER=deepseek            # deepseek | kimi | anthropic
MODEL_ID=                          # optional; defaults per provider
MODEL_API_KEY=
MODEL_BASE_URL=                    # optional; overrides the provider default

# --- Persistence ---
PERSISTENCE_PROVIDER=supabase      # supabase | memory
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=         # server-only secret; bypasses RLS to write events

# --- Sync + GitHub ---
SYNC_MODE=realtime                 # realtime | poll
GITHUB_MODE=pr                     # pr | direct | off
GITHUB_TOKEN=

# --- Caps (the cost ceiling) ---
MAX_CONCURRENT_AGENTS=3
MONTHLY_BUDGET_USD=40

# Must match the web app's value — used to decrypt a company's sensitive BYOK
# settings (e.g. their model API key, GitHub token) before running agents.
SETTINGS_ENCRYPTION_KEY=
