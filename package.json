{
  "name": "ourai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "OurAI — a multiplayer AI workspace: many humans watch and steer AI coding agents over one shared repo, in real time.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "turbo": "^2.5.0",
    "typescript": "^7.0.2"
  }
}
